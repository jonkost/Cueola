{
  "status": "reference-only",
  "schemaVersion": 1,
  "layers": {
    "background": "full-window canvas",
    "content": "tables, cards, forms, documents, scripts, and media",
    "function": "navigation, toolbars, popovers, sheets, and compact controls"
  },
  "materials": {
    "content": {
      "translucent": false,
      "usage": "default content surface"
