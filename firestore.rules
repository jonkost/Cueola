rules_version = '2';

// v2.1 (D1): STUDENTS still have no username/password authentication — codes
// and profiles are unchanged (university rule, enforced structurally). ADMINS
// now sign in through Firebase Auth (Email/Password with synthetic
// <username>@admins.cueola.app emails); authorization is the uid-keyed
// admins/{uid} doc checked by isAdmin()/isSuperAdmin() below. App Check stays
// the perimeter control for everything else; shape validation keeps an
// accepted client from creating arbitrary collections or unbounded structures.
//
// DEPLOY DISCIPLINE (D8 rule 3): this file contains TIGHTENING changes
// (admin-gated accessCodes minting + session delete; Phase 10 adds admin-gated
// LIST on sessions and accessCodes). Deploy only in the release-day sequence:
// hosting first → fleet refresh → instructors minted → then these rules.
// Rollback copy: docs/rules-rollback-2026-07-18-pre-admin-auth.rules
//
// Phase 10 residual, recorded on purpose: profiles LIST stays open. The
// student-side paperwork export and roster hydration (hydrateRoleAssignments →
// full profiles read, cueola-app.js) run for crew members with no Auth — the
// university rule prohibits student sign-in, and Firestore list rules cannot
// express "only profiles sharing a session with the caller". Scoping it to
// isAdmin() breaks student exports. Perimeter control is App Check; the
// long-term fix (server-resolved roster) is 3.0 territory.
service cloud.firestore {
  match /databases/{database}/documents {

    // ── v2.1 admin identity (D1) ────────────────────────────────
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isSuperAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.level == 'super';
    }
    function validAdminAccountDocument(data) {
      return data is map
        && data.keys().hasAll(['username', 'name', 'level'])
        && data.username is string
        && data.username.matches('^[a-z0-9][a-z0-9._-]{2,39}$')
        && shortString(data.name, 120)
        && data.level in ['super', 'standard']
        && (!data.keys().hasAny(['createdAt']) || data.createdAt is int)
        && optionalShortString(data, 'createdBy', 160);
    }

    function shortString(value, limit) {
      return value is string && value.size() > 0 && value.size() <= limit;
    }

    function optionalShortString(data, key, limit) {
      return !data.keys().hasAny([key]) || shortString(data[key], limit);
    }

    function validSessionId(code) {
      // Includes ordinary session codes and the legacy pbfile_* sibling docs.
      return code.matches('^[A-Za-z0-9_.-]{1,160}$');
    }

    function validSessionDocument(code, data) {
      // Session docs are intentionally extensible: Cueola, Flowmingo,
      // Outrangutan, dashboard, and Prompt-Up share this document.
      return data is map
        && (!data.keys().hasAny(['code']) || data.code == code)
        && optionalShortString(data, 'showName', 200)
        && optionalShortString(data, 'createdBy', 120)
        && (!data.keys().hasAny(['beats']) || data.beats is list)
        && (!data.keys().hasAny(['cues']) || data.cues is list)
        && (!data.keys().hasAny(['participants']) || data.participants is list)
        && (!data.keys().hasAny(['presence']) || data.presence is map)
        && (!data.keys().hasAny(['prompter']) || data.prompter is map)
        && (!data.keys().hasAny(['outrangutan']) || data.outrangutan is map)
        && (!data.keys().hasAny(['prePro']) || data.prePro is map)
        && (!data.keys().hasAny(['assignments']) || data.assignments is map)
        && (!data.keys().hasAny(['roleAssignments']) || data.roleAssignments is list)
        && (!data.keys().hasAny(['assignmentRevision'])
          || (data.assignmentRevision is int && data.assignmentRevision >= 0))
        && (!data.keys().hasAny(['assignmentUpdatedAt'])
          || (data.assignmentUpdatedAt is int && data.assignmentUpdatedAt >= 0))
        && optionalShortString(data, 'assignmentUpdatedBy', 160)
        // Dashboard soft-delete stamp (Phase 1 item 4): restore removes both keys.
        && (!data.keys().hasAny(['deletedAt']) || data.deletedAt is int)
        && optionalShortString(data, 'deletedBy', 120)
        // Phase 3 per-session admin toggle: entry also requires a class login code.
        && (!data.keys().hasAny(['requireLoginCode']) || data.requireLoginCode is bool)
        // v2.1 (D1): session ownership by admin Auth uid.
        && optionalShortString(data, 'ownerUid', 160)
        // v2.1 (D2/D5): groups config + clone lineage — hygiene type checks
        // (validSessionDocument has no field allowlist; these are not gates).
        && (!data.keys().hasAny(['groups']) || data.groups is list)
        && (!data.keys().hasAny(['groupsLocked']) || data.groupsLocked is bool)
        && optionalShortString(data, 'clonedFrom', 160);
    }

    function validFileDocument(code, fileId, data) {
      return fileId.matches('^[A-Za-z0-9_.-]{1,160}$')
        && data is map
        && data.keys().hasOnly([
          'kind', 'fileId', 'parentFileId', 'session', 'name', 'type', 'size',
          'chunkCount', 'data', 'at', 'chunkIndex'
        ])
        && shortString(data.kind, 40)
        && data.kind in ['pbNoteFile', 'pbNoteFileChunk']
        && (!data.keys().hasAny(['fileId']) || data.fileId == fileId)
        && (!data.keys().hasAny(['parentFileId']) || data.parentFileId.matches('^[A-Za-z0-9_.-]{1,160}$'))
        && (!data.keys().hasAny(['session']) || data.session == code)
        && optionalShortString(data, 'name', 240)
        && optionalShortString(data, 'type', 160)
        && (!data.keys().hasAny(['size']) || (data.size is int && data.size >= 0 && data.size <= 10485760))
        && (!data.keys().hasAny(['chunkCount']) || (data.chunkCount is int && data.chunkCount >= 1 && data.chunkCount <= 8))
        && (!data.keys().hasAny(['chunkIndex']) || (data.chunkIndex is int && data.chunkIndex >= 1 && data.chunkIndex < 8))
        && (!data.keys().hasAny(['data']) || (data.data is string && data.data.size() <= 800000));
    }

    // v2.1 Phase 7 (D3): cloud snapshot docs — mirrors validFileDocument's
    // shape discipline for the chunked gzip+base64 payload.
    function validSnapshotDocument(code, data) {
      return data is map
        && data.keys().hasOnly([
          'kind', 'sessionCode', 'createdAt', 'reason', 'summary', 'fpHash',
          'encoding', 'bytes', 'chunkCount', 'chunkIndex', 'createdBy', 'data'
        ])
        && shortString(data.kind, 40)
        && data.kind in ['sessionSnapshot', 'sessionSnapshotChunk']
        && (!data.keys().hasAny(['sessionCode']) || data.sessionCode == code)
        && (!data.keys().hasAny(['createdAt']) || data.createdAt is number)
        && optionalShortString(data, 'reason', 40)
        && optionalShortString(data, 'summary', 500)
        && (!data.keys().hasAny(['fpHash']) || (data.fpHash is string && data.fpHash.matches('^[a-f0-9]{16}$')))
        && (!data.keys().hasAny(['encoding']) || data.encoding in ['gzip-b64', 'json-b64'])
        && (!data.keys().hasAny(['bytes']) || (data.bytes is int && data.bytes >= 0 && data.bytes <= 10485760))
        && (!data.keys().hasAny(['chunkCount']) || (data.chunkCount is int && data.chunkCount >= 1 && data.chunkCount <= 8))
        && (!data.keys().hasAny(['chunkIndex']) || (data.chunkIndex is int && data.chunkIndex >= 1 && data.chunkIndex < 8))
        && optionalShortString(data, 'createdBy', 160)
        && (!data.keys().hasAny(['data']) || (data.data is string && data.data.size() <= 800000));
    }

    function validAccessCode(data) {
      return data is map
        && data.keys().hasAll(['role', 'label', 'active', 'createdBy', 'createdAt'])
        && data.keys().hasOnly(['role', 'label', 'active', 'createdBy', 'createdAt', 'revokedAt', 'revokedBy'])
        && data.role in ['student', 'admin']
        && shortString(data.label, 160)
        && data.active is bool
        && shortString(data.createdBy, 120)
        && (!data.keys().hasAny(['revokedAt']) || data.revokedAt is int)
        && optionalShortString(data, 'revokedBy', 120);
    }

    function validUsername(username) {
      return username.matches('^[a-z0-9][a-z0-9._-]{2,39}$');
    }

    function validCanonicalId(value) {
      return value is string
        && value.matches('^[A-Za-z0-9_.-]{3,160}$');
    }

    function validProfile(username, data) {
      return validUsername(username)
        && data is map
        && data.keys().hasAll([
          'username', 'fullName', 'role', 'avatar', 'theme', 'sessions',
          'codeUsed', 'createdAt', 'lastSeen'
        ])
        && data.keys().hasOnly([
          'username', 'fullName', 'role', 'avatar', 'theme', 'sessions',
          'codeUsed', 'createdAt', 'lastSeen', 'active', 'renamedTo', 'mergedInto',
          'profileId', 'profileAliases'
        ])
        && data.username.lower() == username
        && shortString(data.username, 40)
        && shortString(data.fullName, 120)
        && data.role in ['student', 'admin']
        && data.avatar is map
        && shortString(data.theme, 40)
        && data.sessions is list
        && data.sessions.size() <= 100
        && shortString(data.codeUsed, 80)
        // Phase 6 migration fields are optional for legacy profiles. Once a
        // profileId is added, immutableProfileId() prevents removing/changing it.
        && (!data.keys().hasAny(['profileId']) || validCanonicalId(data.profileId))
        && (!data.keys().hasAny(['profileAliases'])
          || (data.profileAliases is list && data.profileAliases.size() <= 40))
        && (!data.keys().hasAny(['active']) || data.active is bool)
        && optionalShortString(data, 'renamedTo', 40)
        && optionalShortString(data, 'mergedInto', 40);
    }

    function activeCodeForProfile(data) {
      let path = /databases/$(database)/documents/accessCodes/$(data.codeUsed);
      return exists(path)
        && get(path).data.active == true
        && get(path).data.role == data.role;
    }

    function immutableProfileIdentity() {
      return request.resource.data.username == resource.data.username
        && request.resource.data.role == resource.data.role
        && request.resource.data.codeUsed == resource.data.codeUsed
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function immutableProfileId() {
      // Existing profiles may add an opaque id once. Profiles that already have
      // one must preserve it on every subsequent update.
      return (!resource.data.keys().hasAny(['profileId']))
        || (request.resource.data.keys().hasAny(['profileId'])
          && request.resource.data.profileId == resource.data.profileId);
    }

    function validAssignment(assignmentId, code, data) {
      return validCanonicalId(assignmentId)
        // productionSession is a foreign key to the existing session path.
        // Preserve Cueola's 1–160 character session-code contract; generated
        // assignment/profile/position identifiers use validCanonicalId().
        && validSessionId(code)
        && data is map
        && data.keys().hasAll([
          'assignmentId', 'productionSession', 'profileId', 'displayName',
          'positionId', 'positionLabel', 'paperworkIds', 'paperworkLabels',
          'status', 'assignedBy', 'assignedByLabel', 'createdAt', 'updatedAt',
          'revision'
        ])
        && data.keys().hasOnly([
          'assignmentId', 'productionSession', 'profileId', 'displayName',
          'positionId', 'positionLabel', 'paperworkIds', 'paperworkLabels',
          'status', 'assignedBy', 'assignedByLabel', 'createdAt', 'updatedAt',
          'revision'
        ])
        && data.assignmentId == assignmentId
        && data.productionSession == code
        && validCanonicalId(data.profileId)
        && shortString(data.displayName, 160)
        && validCanonicalId(data.positionId)
        && shortString(data.positionLabel, 160)
        && data.paperworkIds is list
        && data.paperworkIds.size() <= 40
        && data.paperworkLabels is list
        && data.paperworkLabels.size() == data.paperworkIds.size()
        && data.status in ['assigned', 'completed']
        && validCanonicalId(data.assignedBy)
        && shortString(data.assignedByLabel, 160)
        && data.createdAt is int
        && data.createdAt >= 0
        && data.updatedAt is int
        && data.updatedAt >= data.createdAt
        && data.revision is int
        && data.revision >= 1
        && data.revision <= 1000000;
    }

    function immutableAssignmentIdentity() {
      return request.resource.data.assignmentId == resource.data.assignmentId
        && request.resource.data.productionSession == resource.data.productionSession
        && request.resource.data.profileId == resource.data.profileId
        && request.resource.data.positionId == resource.data.positionId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt >= resource.data.updatedAt
        && request.resource.data.revision > resource.data.revision;
    }

    function validNote(noteId, data) {
      return noteId.matches('^[A-Za-z0-9_.-]{1,160}$')
        && data is map
        && data.keys().hasOnly([
          'id', 'text', 'by', 'role', 'tag', 'assignee', 'done', 'doneBy',
          'doneAt', 'at', 'clientId', 'replyTo', 'editedAt', 'pinned', 'avatar',
          'likes', 'mentions', 'checklist', 'attachments', 'replies', 'seenBy'
        ])
        && (!data.keys().hasAny(['id']) || data.id == noteId)
        && optionalShortString(data, 'text', 20000)
        && optionalShortString(data, 'by', 120)
        && (!data.keys().hasAny(['role']) || data.role in ['student', 'instructor', 'admin'])
        && optionalShortString(data, 'tag', 40)
        && optionalShortString(data, 'assignee', 120)
        // Phase 4 per-note migration: the client writes these fields verbatim.
        && (!data.keys().hasAny(['done']) || data.done is bool)
        && (!data.keys().hasAny(['pinned']) || data.pinned is bool)
        && (!data.keys().hasAny(['at']) || data.at is int)
        && (!data.keys().hasAny(['doneAt']) || data.doneAt is int)
        && (!data.keys().hasAny(['editedAt']) || data.editedAt is int)
        && optionalShortString(data, 'doneBy', 120)
        && optionalShortString(data, 'clientId', 120)
        && (!data.keys().hasAny(['replyTo']) || data.replyTo is string && data.replyTo.size() <= 160)
        && (!data.keys().hasAny(['avatar']) || data.avatar is map)
        && (!data.keys().hasAny(['likes']) || (data.likes is list && data.likes.size() <= 500))
        && (!data.keys().hasAny(['mentions']) || (data.mentions is list && data.mentions.size() <= 100))
        && (!data.keys().hasAny(['checklist']) || (data.checklist is list && data.checklist.size() <= 100))
        && (!data.keys().hasAny(['attachments']) || (data.attachments is list && data.attachments.size() <= 40))
        && (!data.keys().hasAny(['replies']) || (data.replies is list && data.replies.size() <= 500))
        && (!data.keys().hasAny(['seenBy']) || (data.seenBy is map && data.seenBy.size() <= 200));
    }

    // Shared show state. App Check enforcement in Firebase Console is the only
    // current way to distinguish Cueola clients from arbitrary callers.
    match /sessions/{code} {
      allow get: if validSessionId(code);
      // v2.1 Phase 10: enumerating sessions is admin-only. No shipped surface
      // lists this collection today (the dashboard tracks known codes and
      // reads them individually), so this closes pure recon: an accepted
      // client could otherwise walk every production. (TIGHTENING —
      // release-day deploy.)
      allow list: if isAdmin();
      allow create, update: if validSessionId(code) && validSessionDocument(code, request.resource.data);
      // v2.1 (D1): destroying a session is admin-only. (TIGHTENING —
      // release-day deploy; the dashboard purge runs signed-in.)
      allow delete: if validSessionId(code) && isAdmin();

      // Phase 1 item 3 target. Reads/writes are shape-limited now so the rules
      // can be deployed before the client migration without reopening rules.
      match /files/{fileId} {
        allow get, delete: if validSessionId(code) && fileId.matches('^[A-Za-z0-9_.-]{1,160}$');
        allow list: if validSessionId(code);
        allow create, update: if validSessionId(code) && validFileDocument(code, fileId, request.resource.data);
      }

      // Phase 4 per-note target.
      match /notes/{noteId} {
        allow get, delete: if validSessionId(code) && noteId.matches('^[A-Za-z0-9_.-]{1,160}$');
        allow list: if validSessionId(code);
        allow create, update: if validSessionId(code) && validNote(noteId, request.resource.data);
      }

      // v2.1 (D2): one paperwork workspace per group. The doc shape mirrors
      // today's session-doc paperwork fields; group ids are identifier-safe
      // so masked prePro.<key> patches stay legal.
      match /groups/{groupId} {
        allow get, delete: if validSessionId(code) && groupId.matches('^[A-Za-z_][A-Za-z0-9_]{0,63}$');
        allow list: if validSessionId(code);
        allow create, update: if validSessionId(code)
          && groupId.matches('^[A-Za-z_][A-Za-z0-9_]{0,63}$')
          && request.resource.data is map
          && (!request.resource.data.keys().hasAny(['prePro']) || request.resource.data.prePro is map)
          && (!request.resource.data.keys().hasAny(['preProActivity']) || request.resource.data.preProActivity is list);
      }

      // Canonical Phase 6 crew assignments. These rules validate consistency
      // and bounds only: without Firebase Auth they cannot prove whether the
      // caller is an instructor, administrator, or student.
      match /assignments/{assignmentId} {
        allow get, delete: if validSessionId(code) && validCanonicalId(assignmentId);
        allow list: if validSessionId(code);
        allow create: if validSessionId(code)
                      && validAssignment(assignmentId, code, request.resource.data);
        allow update: if validSessionId(code)
                      && validAssignment(assignmentId, code, request.resource.data)
                      && immutableAssignmentIdentity();
      }

      // v2.1 Phase 7 (D3): cloud snapshot trail — the ONE subcollection with
      // zero student-read requirement. Snapshots embed the full session
      // (student names in paperwork), so everything is admin-gated from day
      // one; delete stays allowed because snapshots MUST be purgeable (PII
      // retention). `update` carries the same checks as create: content-hash
      // ids make identical concurrent captures converge onto one doc via
      // idempotent setDoc. ADDITIVE — deploys BEFORE the JS ships to hosting
      // (D8 rule 3): cloudSnapshotPut is fire-and-forget, so shipping the JS
      // first would produce silently-failing cloud captures.
      match /snapshots/{snapId} {
        allow read, delete: if validSessionId(code) && isAdmin()
          && snapId.matches('^snap_[a-f0-9]{16}(_c[1-7])?$');
        allow create, update: if validSessionId(code) && isAdmin()
          && snapId.matches('^snap_[a-f0-9]{16}(_c[1-7])?$')
          && validSnapshotDocument(code, request.resource.data);
      }
    }

    match /admins/{docId} {
      // v2.1 (D1): uid-keyed admin accounts. Reads need only a signed-in Auth
      // user (a fresh admin must read their own doc to resolve their session);
      // writes are super-only, and no one can delete their own doc (lockout
      // guard). The legacy 'global' list-doc is FROZEN read-only for one
      // release as rollback safety — its writes are gone.
      allow read: if docId == 'global' || request.auth != null;
      allow create, update: if docId != 'global'
        && isSuperAdmin()
        && validAdminAccountDocument(request.resource.data);
      allow delete: if docId != 'global'
        && isSuperAdmin()
        && docId != request.auth.uid;
    }

    // Entitlements are server-authoritative. Admin SDK/server writes bypass rules.
    match /accounts/{accountId} {
      allow read: if accountId.matches('^[A-Za-z0-9_.-]{1,160}$');
      allow write: if false;
    }

    // Phase 3 identity layer. This is consistency, not authentication: without
    // Firebase Auth an accepted client can still mint an access-code document.
    match /accessCodes/{code} {
      allow get: if code.matches('^[A-Za-z0-9_-]{4,80}$');
      // v2.1 Phase 10: kills the open list — an accepted client could walk
      // every class key. Entry gates `get` a specific code; only the signed-in
      // dashboard lists them (mint/revoke panel). (TIGHTENING — release-day
      // deploy.)
      allow list: if isAdmin();
      // v2.1 (D1): minting/updating class codes is admin-only — kills the
      // public admin-code minting hole. (TIGHTENING — release-day deploy.)
      allow create, update: if isAdmin()
        && code.matches('^[A-Za-z0-9_-]{4,80}$')
        && validAccessCode(request.resource.data);
      allow delete: if false;
    }

    match /profiles/{username} {
      allow get: if validUsername(username);
      // Phase 10 decision: list stays OPEN (see header). Student crew exports
      // and roster hydration read the whole collection without Auth; tightening
      // this to isAdmin() breaks them. Do not "clean this up" without moving
      // roster resolution server-side first.
      allow list: if true;
      allow create: if validProfile(username, request.resource.data)
                    && activeCodeForProfile(request.resource.data);
      allow update: if validProfile(username, request.resource.data)
                    && immutableProfileIdentity()
                    && immutableProfileId();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
