rules_version = '2';

// Cueola Firestore security rules.
//
// READ THIS BEFORE TRUSTING THESE RULES.
// This app has no user accounts: talent, operators, and collaborators all share
// a short session code and NO Firebase Auth is loaded, so `request.auth` is
// always null. Rules therefore cannot tell a real user apart from an attacker
// running curl/Burp. Anyone who knows the project id can read, list, overwrite,
// or delete any session. (Prompt-Up-The-Jam also reads this same project's
// `sessions`, so keep session reads working.)
//
// The real protection for an app with no logins is Firebase App Check (enable
// and ENFORCE it on Firestore in the console — it needs no user accounts). To
// lock data down per-user, add Anonymous/Email Auth and gate on request.auth.
//
// NOTE: validate these in the Rules Playground / emulator before publishing.

service cloud.firestore {
  match /databases/{database}/documents {

    // Shared show sessions, keyed by the short code (e.g. "2605K").
    // Holds the rundown, prompter.text, prompter.control, prompter.talentHeartbeat,
    // prompter.controlAck, presence, etc. Read covers both single-doc get and the
    // dashboard's full-collection list query. Left open (no auth to gate on);
    // App Check is what keeps non-app clients out.
    match /sessions/{code} {
      allow read, write: if true;
    }

    // Admin roster — a single document at admins/global, written as { list: [...] }.
    // Still publicly writable (no auth), but pin the shape so it can't be stuffed
    // with arbitrary fields or an oversized roster. REAL FIX: Firebase Auth.
    match /admins/{docId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['list'])
                     && request.resource.data.list is list
                     && request.resource.data.list.size() <= 200;
    }

    // Lock down everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
